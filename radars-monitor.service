[Unit]
Description=RadarsMonitor - Radar visualization application
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=/bin/bash /home/ideon/RadarsMonitor/run.sh
WorkingDirectory=/home/ideon/RadarsMonitor
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=10
User=ideon
Environment="PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

[Install]
WantedBy=multi-user.target
